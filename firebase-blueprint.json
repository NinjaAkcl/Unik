{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile info.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["email", "createdAt", "updatedAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Store product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number", "description": "Used for sales: if originalPrice > price, product is on sale" },
        "category": { "type": "string" },
        "type": { "type": "string" },
        "season": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "inventory": { "type": "object", "additionalProperties": { "type": "number" } },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "price", "category", "images", "sizes", "createdAt", "updatedAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Admin marker",
      "type": "object",
      "properties": {},
      "required": []
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile collection"
    },
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Store products inventory"
    },
    "admins/{userId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Admin users list"
    }
  }
}
